  "keyFeatures": [
    "Synchronized YouTube video playback across all users",
    "Real-time chat with typing indicators and message history",
    "Host-controlled room management with guest promotion",
    "Automatic room cleanup when all hosts leave",
    "Redis-backed persistence for rooms and chat",
    "Rate limiting for both HTTP and Socket.IO connections",
    "Docker and Docker Compose support for easy deployment"
  ],
  "publicApiSurface": [
    "Room Events: create-room, join-room, leave-room, promote-host",
